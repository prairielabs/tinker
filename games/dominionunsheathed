SECTION 11 — OUTPUT PARSER (Δ extraction)
───────────────────────────────────────────────────────────────────────────────
OutputParser DominionOutputParser

FUNCTION parse
INPUT:
  raw : text
OUTPUT:
  delta : Delta

PROCESS:
  delta ← Delta {
    axis_changes : []
    new_tags     : []
    removed_tags : []
    phase_change : null
    entropy_hint : null
    narrative    : raw
  }

  IF contains(raw, "[STATE_UPDATE]") THEN
    block ← extract_between(raw, "[STATE_UPDATE]", "[/STATE_UPDATE]")

    // Axis changes: id: +/-number  (DISPLAY-UNIT DELTAS)
    axis_pattern ← regex("([a-zA-Z_]+)\\s*:\\s*([+-]?\\d*\\.?\\d+)")
    FOR EACH match IN find_all(block, axis_pattern) DO
      axis_id ← match[1]
      val ← parse_number(match[2])
      IF axis_id IN ["legitimacy","military_strength","treasury","stores","public_order","noble_loyalty","war_exhaustion","intel_clarity"] THEN
        delta.axis_changes += [{ axis_id: axis_id, change: val }]

    // Tags add/remove
    IF contains(block, "+TAG:") THEN
      tags_line ← extract_after(block, "+TAG:")
      delta.new_tags ← split_by_commas(trim(tags_line))

    IF contains(block, "-TAG:") THEN
      tags_line ← extract_after(block, "-TAG:")
      delta.removed_tags ← split_by_commas(trim(tags_line))

    // Phase
    IF contains(block, "PHASE:") THEN
      delta.phase_change ← trim(extract_after(block, "PHASE:"))

    // Narrative excludes the state block
    delta.narrative ← extract_before(raw, "[STATE_UPDATE]")

  RETURN delta
END


