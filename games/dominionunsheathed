UpdateRules DominionUpdateRules

FUNCTION apply_delta
INPUT:
  W     : WorldState
  delta : Delta   (axis changes are display-unit deltas)
OUTPUT:
  W_next: WorldState

PROCESS:
  1) Deep copy W → W_next

  2) Apply axis changes (DISPLAY UNITS):
     FOR EACH change IN delta.axis_changes DO
       axis ← find_axis(W_next.axes, change.axis_id)
       IF axis != null THEN
         // denormalize current
         cur_display ← axis.min + axis.value * (axis.max - axis.min)
         // apply display delta
         new_display ← cur_display + change.change
         // clamp
         new_display ← clamp(new_display, axis.min, axis.max)
         // renormalize
         axis.value ← (new_display - axis.min) / (axis.max - axis.min)

  3) Apply tag changes:
     - Add delta.new_tags (if not present)
     - Remove delta.removed_tags (if present)

  4) Apply phase change if provided:
     IF delta.phase_change != null THEN
       W_next.symbolic.phase ← delta.phase_change

  5) Passive upkeep tick (always; small, grounded):
     // These are *baseline* pressures. They keep the world moving.
     // Values are DISPLAY-UNIT deltas applied via same denorm->apply->renorm logic.

     IF "at_war" IN W_next.symbolic.tags THEN
        treasury        -= 18
        stores          -= 4
        war_exhaustion  += 3
        public_order    -= 1

     IF "under_siege" IN W_next.symbolic.tags THEN
        stores       -= 6
        public_order -= 2

     IF "winter" IN W_next.symbolic.tags THEN
        stores       -= 5
        military_strength -= 1

     IF "famine" IN W_next.symbolic.tags THEN
        public_order -= 4
        legitimacy   -= 2

     IF "plague" IN W_next.symbolic.tags THEN
        military_strength -= 3
        public_order      -= 2
        noble_loyalty     -= 1

     IF "rebellion" IN W_next.symbolic.tags THEN
        public_order   -= 5
        legitimacy     -= 3
        military_strength -= 2

     // If treasury critically low, order suffers (late pay → unrest)
     IF display_value("treasury") < 120 THEN
        public_order -= 2
        noble_loyalty -= 2

     // If stores critically low, exhaustion rises
     IF display_value("stores") < 20 THEN
        war_exhaustion += 4
        public_order   -= 3

  6) Ensure mutual exclusivity (safety coherence):
     - war_state tags: keep only one of {at_peace, at_war, truce, civil_war, holy_war} if present
     - season tags: keep only one of {winter, campaign_season} if present
     (Resolve by preferring the most “severe/active” tag mentioned most recently.)

  7) Memory turn count increments:
     W_next.memory.turn_count ← W_next.memory.turn_count + 1

  RETURN W_next
END


FUNCTION compute_tension
INPUT:
  W   : WorldState
OUTPUT:
  tau : number [0,1]

PROCESS:
  // Tension increases when survival pillars are threatened.
  // Compute in DISPLAY SPACE, then map to 0..1.

  leg      ← display_value("legitimacy")       // 0..100
  mil      ← display_value("military_strength")// 0..100
  gold     ← display_value("treasury")         // 0..1200
  food     ← display_value("stores")           // 0..100
  order    ← display_value("public_order")     // 0..100
  nobles   ← display_value("noble_loyalty")    // 0..100
  weary    ← display_value("war_exhaustion")   // 0..100
  intel    ← display_value("intel_clarity")    // 0..100

  // Convert to risk signals (0 low risk, 1 high risk)
  risk_leg    ← clamp((40 - leg) / 40, 0, 1)
  risk_food   ← clamp((30 - food) / 30, 0, 1)
  risk_order  ← clamp((35 - order) / 35, 0, 1)
  risk_gold   ← clamp((160 - gold) / 160, 0, 1)
  risk_mil    ← clamp((35 - mil) / 35, 0, 1)
  risk_nobles ← clamp((40 - nobles) / 40, 0, 1)
  risk_weary  ← clamp((weary - 55) / 45, 0, 1)
  risk_intel  ← clamp((35 - intel) / 35, 0, 1)

  base ← average([risk_leg,risk_food,risk_order,risk_gold,risk_mil,risk_nobles,risk_weary,risk_intel])

  // Tag modifiers (categorical spikes)
  tag_boost ← 0
  IF "rebellion" IN tags THEN tag_boost += 0.12
  IF "foreign_invasion" IN tags THEN tag_boost += 0.15
  IF "under_siege" IN tags THEN tag_boost += 0.10
  IF "plague" IN tags THEN tag_boost += 0.10
  IF "famine" IN tags THEN tag_boost += 0.10
  IF "succession_crisis" IN tags THEN tag_boost += 0.10
  IF "council_divided" IN tags THEN tag_boost += 0.06

  tau ← clamp(base + tag_boost, 0, 1)
  RETURN tau
END


